# Brain MCP Server — Environment Variables
# Copy to .env for local dev, or set in Render Dashboard -> Environment

# Neo4j Aura credentials
NEO4J_URI=neo4j+s://XXXXXXXX.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Pinecone credentials
PINECONE_API_KEY=
PINECONE_INDEX=pws-brain

# Supabase (primary auth — validates keys against brain_api_keys table)
SUPABASE_URL=https://ulmymxxmvsehjiyymqoi.supabase.co
SUPABASE_SERVICE_KEY=  # Get from Supabase Dashboard → Settings → API → service_role

# Fallback: comma-separated API keys (used when Supabase is down or not configured)
BRAIN_API_KEYS=

# Port (Render sets this automatically)
PORT=3001
