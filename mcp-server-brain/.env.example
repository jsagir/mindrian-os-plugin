# Brain MCP Server — Environment Variables
# Copy to .env for local dev, or set in Render Dashboard -> Environment

# Neo4j Aura credentials
NEO4J_URI=neo4j+s://XXXXXXXX.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Pinecone credentials
PINECONE_API_KEY=
PINECONE_INDEX=pws-brain

# API keys for paid-tier access (comma-separated UUIDs)
# Generate: node -e "console.log(require('crypto').randomUUID())"
BRAIN_API_KEYS=

# Port (Render sets this automatically)
PORT=3001
