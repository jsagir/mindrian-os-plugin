# MindrianOS Brain MCP — Connection Credentials
# Copy this file to .env.brain and fill in your values
#
# To use: add the Brain MCP server to your claude_desktop_config.json
# with these environment variables passed through.

# Neo4j Aura (from Aura console → Connection Details)
NEO4J_URI=neo4j+s://XXXXXXXX.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here

# Pinecone (from Pinecone console → API Keys)
PINECONE_API_KEY=your-pinecone-key-here
PINECONE_INDEX=pws-brain
