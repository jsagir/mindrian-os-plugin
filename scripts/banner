#!/usr/bin/env bash
# banner: De Stijl Mondrian ASCII art banner for MindrianOS
# Usage: bash scripts/banner [version]
#
# Full block-letter "MindrianOS" with 4 background color zones
# creating a Mondrian grid composition. Bottom bar adds a 5th color.
#
# ┌──────────────────┬──────────────────┬──────────────────┬──────────────────┐
# │   M I N (red)    │  D R I (blue)    │  A N (yellow)    │   O S (teal)     │
# ├──────────────────┴────────────┬─────┴──────────────────┴──────────────────┤
# │  tagline (green)              │                     version (red)         │
# └───────────────────────────────┴───────────────────────────────────────────┘

set -euo pipefail

VERSION="${1:-}"
if [ -z "$VERSION" ]; then
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
  VERSION=$(python3 -c "import json; print(json.load(open('${PLUGIN_ROOT}/.claude-plugin/plugin.json'))['version'])" 2>/dev/null || echo "")
fi

# De Stijl Mondrian palette -- 24-bit ANSI
RB=$'\e[48;2;166;61;47m'     # Red bg    #A63D2F
BB=$'\e[48;2;30;58;110m'     # Blue bg   #1E3A6E
YB=$'\e[48;2;200;164;60m'    # Yellow bg #C8A43C
TB=$'\e[48;2;42;107;94m'     # Teal bg   #2A6B5E
GB=$'\e[48;2;45;107;74m'     # Green bg  #2D6B4A
CF=$'\e[38;2;245;240;232m'   # Cream fg  #F5F0E8
MF=$'\e[38;2;160;154;144m'   # Muted fg  #A09A90
RS=$'\e[0m'                   # Reset

# Full MindrianOS block letters (78 chars per row)
# Split into 4 Mondrian zones: MIN(24) DRI(18) AN(18) OS(18)
L1='███╗   ███╗██╗███╗   ██╗██████╗ ██████╗ ██╗ █████╗ ███╗   ██╗ ██████╗ ███████╗'
L2='████╗ ████║██║████╗  ██║██╔══██╗██╔══██╗██║██╔══██╗████╗  ██║██╔═══██╗██╔════╝'
L3='██╔████╔██║██║██╔██╗ ██║██║  ██║██████╔╝██║███████║██╔██╗ ██║██║   ██║███████╗'
L4='██║╚██╔╝██║██║██║╚██╗██║██║  ██║██╔══██╗██║██╔══██║██║╚██╗██║██║   ██║╚════██║'
L5='██║ ╚═╝ ██║██║██║ ╚████║██████╔╝██║  ██║██║██║  ██║██║ ╚████║╚██████╔╝███████║'
L6='╚═╝     ╚═╝╚═╝╚═╝  ╚═══╝╚═════╝ ╚═╝  ╚═╝╚═╝╚═╝  ╚═╝╚═╝  ╚═══╝ ╚═════╝ ╚══════╝'

# Bottom Mondrian bar: tagline(green, 45) + version(red, 33) = 78
VER="v${VERSION}"
VLEN=${#VER}
VLP=$(( (33 - VLEN) / 2 ))
VRP=$(( 33 - VLEN - VLP ))
VPAD=$(printf '%*s%s%*s' "$VLP" '' "$VER" "$VRP" '')
TPAD=$(printf '%9s%s%9s' '' 'Wicked problems. Navigated.' '')

# Render the Mondrian composition
printf '\n'
for L in "$L1" "$L2" "$L3" "$L4" "$L5" "$L6"; do
  printf "  %s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s\n" \
    "$RB" "$CF" "${L:0:24}"  "$RS" \
    "$BB" "$CF" "${L:24:18}" "$RS" \
    "$YB" "$CF" "${L:42:18}" "$RS" \
    "$TB" "$CF" "${L:60:18}" "$RS"
done
printf '\n'
printf "  %s%s%s%s%s%s%s%s\n" \
  "$GB" "$CF" "$TPAD" "$RS" \
  "$RB" "$CF" "$VPAD" "$RS"
printf '\n'
printf "  %smindrian.ai | Jonathan Sagir | linkedin.com/in/jonathansagir%s\n" "$MF" "$RS"
printf '\n'
