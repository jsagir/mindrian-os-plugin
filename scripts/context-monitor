#!/usr/bin/env node
// MindrianOS Statusline — ships with the plugin
// Shows: project name │ room section context │ venture stage │ gaps │ context window
// Reads JSON from stdin (Claude Code statusline API)

'use strict';

const fs = require('fs');
const path = require('path');
const visual = require('../lib/core/visual-ops.cjs');

const BRIDGE_FILE = '/tmp/mindrian-context-state';

let input = '';
const timeout = setTimeout(() => process.exit(0), 3000);
process.stdin.setEncoding('utf8');
process.stdin.on('data', chunk => input += chunk);
process.stdin.on('end', () => {
  clearTimeout(timeout);
  try {
    const data = JSON.parse(input);
    const model = data.model?.display_name || 'Claude';
    const dir = data.workspace?.current_dir || process.cwd();
    const remaining = data.context_window?.remaining_percentage;
    const usedPct = data.context_window?.used_percentage;

    // Write bridge file for hooks/skills
    try {
      const bridge = JSON.stringify({
        model_id: data.model?.id || 'unknown',
        model_name: model,
        ctx_pct: usedPct || 0,
        ctx_remaining: remaining || 100,
        ctx_size: data.context_window?.context_window_size || 200000,
        timestamp: Math.floor(Date.now() / 1000)
      });
      fs.writeFileSync(BRIDGE_FILE + '.tmp', bridge);
      fs.renameSync(BRIDGE_FILE + '.tmp', BRIDGE_FILE);
    } catch (e) {}

    // --- Context window bar ---
    const AUTO_COMPACT_BUFFER = 16.5;
    let ctx = '';
    if (remaining != null) {
      const usableRemaining = Math.max(0, ((remaining - AUTO_COMPACT_BUFFER) / (100 - AUTO_COMPACT_BUFFER)) * 100);
      const used = Math.max(0, Math.min(100, Math.round(100 - usableRemaining)));
      const filled = Math.floor(used / 10);
      const bar = '\u2588'.repeat(filled) + '\u2591'.repeat(10 - filled);

      if (used < 50) {
        ctx = ` ${visual.ANSI.green}${bar} ${used}%${visual.ANSI.reset}`;
      } else if (used < 65) {
        ctx = ` ${visual.ANSI.yellow}${bar} ${used}%${visual.ANSI.reset}`;
      } else if (used < 80) {
        ctx = ` ${visual.ANSI.sienna}${bar} ${used}%${visual.ANSI.reset}`;
      } else {
        ctx = ` \x1b[5;31m\u{1F480} ${bar} ${used}%\x1b[0m`;
      }
    }

    // --- Room context ---
    let roomInfo = '';
    const roomDir = path.join(dir, 'room');
    if (fs.existsSync(roomDir)) {
      try {
        // Project name from room STATE.md or directory name
        let projectName = path.basename(dir);
        const roomState = path.join(roomDir, 'STATE.md');
        let stage = '';

        if (fs.existsSync(roomState)) {
          const content = fs.readFileSync(roomState, 'utf8');
          const stageMatch = content.match(/venture_stage:\s*(.+)/);
          if (stageMatch) stage = stageMatch[1].trim();
          const nameMatch = content.match(/project_name:\s*(.+)/);
          if (nameMatch) projectName = nameMatch[1].trim();
        }

        // Count sections and gaps
        const sections = fs.readdirSync(roomDir, { withFileTypes: true })
          .filter(d => d.isDirectory() && !d.name.startsWith('.'));
        const sectionCount = sections.length;

        let gaps = 0;
        let activeSections = [];
        for (const s of sections) {
          const sPath = path.join(roomDir, s.name);
          try {
            const mdFiles = fs.readdirSync(sPath).filter(f => f.endsWith('.md') && f !== 'STATE.md');
            if (mdFiles.length === 0) {
              gaps++;
            } else {
              activeSections.push(s.name);
            }
          } catch (e) {}
        }

        // Find most recently modified section (what user is working in)
        let currentSection = '';
        let latestMtime = 0;
        for (const s of sections) {
          const sPath = path.join(roomDir, s.name);
          try {
            const files = fs.readdirSync(sPath).filter(f => f.endsWith('.md'));
            for (const f of files) {
              const stat = fs.statSync(path.join(sPath, f));
              if (stat.mtimeMs > latestMtime) {
                latestMtime = stat.mtimeMs;
                currentSection = s.name;
              }
            }
          } catch (e) {}
        }

        // Build room status parts (De Stijl visual identity)
        const parts = [];
        parts.push(`${visual.ANSI.cyan}${visual.ANSI.bold}${visual.SYMBOLS.brand} ${projectName}${visual.ANSI.reset}`);
        if (stage) {
          const stageSym = visual.stageSymbol(stage);
          parts.push(`${visual.ANSI.amethyst}${stageSym} ${stage}${visual.ANSI.reset}`);
        }
        const healthSym = gaps === 0 ? visual.SYMBOLS.health.populated : visual.SYMBOLS.health.empty;
        parts.push(`${healthSym} ${sectionCount} sections`);
        if (gaps > 0) {
          parts.push(`${visual.ANSI.red}${visual.SYMBOLS.health.empty} ${gaps} gaps${visual.ANSI.reset}`);
        }

        roomInfo = parts.join(` ${visual.ANSI.muted}${visual.SYMBOLS.box.v}${visual.ANSI.reset} `);
      } catch (e) {}
    }

    // --- Output ---
    if (roomInfo) {
      // MindrianOS active: show room context + model + context bar
      process.stdout.write(`${roomInfo} ${visual.ANSI.muted}${visual.SYMBOLS.box.v}${visual.ANSI.reset} ${visual.ANSI.dim}${model}${visual.ANSI.reset}${ctx}`);
    } else {
      // No room: just model + directory + context
      const dirname = path.basename(dir);
      process.stdout.write(`${visual.ANSI.dim}${model}${visual.ANSI.reset} ${visual.ANSI.muted}${visual.SYMBOLS.box.v}${visual.ANSI.reset} ${visual.ANSI.dim}${dirname}${visual.ANSI.reset}${ctx}`);
    }
  } catch (e) {
    // Silent fail
  }
});
