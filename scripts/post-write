#!/usr/bin/env bash
# post-write -- PostToolUse handler for Write operations
# Routes to classify-insight for room file classification
#
# Called by run-hook.cmd when PostToolUse fires after Write tool usage.
# The written file path is passed via TOOL_INPUT_PATH env var or as $1.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
FILE_PATH="${1:-$TOOL_INPUT_PATH}"

if [[ -z "$FILE_PATH" ]]; then
  exit 0
fi

# Initialize room_dir for use by both graph index and git commit
room_dir=""

# Resolve active room for guard check
ACTIVE_ROOM=$("${SCRIPT_DIR}/resolve-room" "$PWD" 2>/dev/null) || ACTIVE_ROOM=""

# Track artifact creation if in room/ or rooms/
if [[ "$FILE_PATH" == */room/* ]] || [[ "$FILE_PATH" == */rooms/* ]]; then
  # Active room guard: skip processing for non-active rooms
  if [ -n "$ACTIVE_ROOM" ]; then
    case "$FILE_PATH" in
      "${ACTIVE_ROOM}"/*) ;; # File is in active room -- proceed
      *) exit 0 ;; # File is in a different room -- skip silently
    esac
  fi
  # Extract section name from path (parent directory of the file)
  section=$(dirname "$FILE_PATH" | xargs basename || true)
  if [ -n "$section" ]; then
    bash "${SCRIPT_DIR}/track-analytics" artifact "$section" 2>/dev/null &
  fi
fi

# Index artifact in LazyGraph (KuzuDB) if it is a .md file in a room
if [[ "$FILE_PATH" == *.md ]]; then
  # Skip STATE.md and ROOM.md (not artifacts)
  basename_file=$(basename "$FILE_PATH")
  if [[ "$basename_file" != "STATE.md" ]] && [[ "$basename_file" != "ROOM.md" ]]; then
    # Walk up from FILE_PATH looking for STATE.md to find room root
    check_dir=$(dirname "$FILE_PATH")
    while [ "$check_dir" != "/" ] && [ "$check_dir" != "." ]; do
      if [ -f "$check_dir/STATE.md" ]; then
        room_dir="$check_dir"
        break
      fi
      check_dir=$(dirname "$check_dir")
    done
    if [ -n "$room_dir" ] && [ -d "$room_dir" ]; then
      # Run graph index in background with timeout (don't block hook)
      PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
      timeout 2 node "${PLUGIN_ROOT}/bin/mindrian-tools.cjs" graph index "$room_dir" "$FILE_PATH" --raw 2>/dev/null &
    fi
  fi
fi

# Run classification on the written file
bash "${SCRIPT_DIR}/classify-insight" "$FILE_PATH"

# Git auto-commit (only fires if room has git initialized -- silent no-op otherwise)
if [[ "$FILE_PATH" == */room/* ]] || [[ "$FILE_PATH" == */rooms/* ]]; then
  if [ -n "$room_dir" ] && [ -d "$room_dir" ]; then
    bash "${SCRIPT_DIR}/git-ops" commit "$room_dir" "$FILE_PATH" 2>/dev/null &
  else
    # Walk up to find room root for non-.md files (room_dir may not be set yet)
    _git_check_dir=$(dirname "$FILE_PATH")
    while [ "$_git_check_dir" != "/" ] && [ "$_git_check_dir" != "." ]; do
      if [ -f "$_git_check_dir/STATE.md" ]; then
        bash "${SCRIPT_DIR}/git-ops" commit "$_git_check_dir" "$FILE_PATH" 2>/dev/null &
        break
      fi
      _git_check_dir=$(dirname "$_git_check_dir")
    done
  fi
fi
