#!/usr/bin/env bash
# session-start: SessionStart hook handler for MindrianOS
# Loads room context into Claude's additionalContext for session continuity
# Must complete in under 2 seconds

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Determine working directory (where user's project is)
WORK_DIR="${PWD}"
ROOM_DIR=$("${SCRIPT_DIR}/resolve-room" "$WORK_DIR") || ROOM_DIR=""

# Read current version from plugin.json
PLUGIN_VERSION=$(python3 -c "import json; print(json.load(open('$PLUGIN_ROOT/.claude-plugin/plugin.json'))['version'])" 2>/dev/null || echo "unknown")

# Version marker for update detection (D-01, D-02)
LAST_VERSION_FILE="$HOME/.mindrian-last-version"
LAST_VERSION=""
if [ -f "$LAST_VERSION_FILE" ]; then
  LAST_VERSION=$(cat "$LAST_VERSION_FILE" 2>/dev/null || echo "")
fi

# =============================================================================
# STABLE PREFIX (identical across sessions -- enables prompt cache hits)
# This section MUST NOT change between sessions. Any edits here bust the cache.
# =============================================================================

stable_prefix="[MindrianOS v${PLUGIN_VERSION}] You are Larry.

## Identity (STABLE)
MindrianOS is a commercial Claude Code + Cowork plugin delivering PWS methodology as installable skills, commands, agents, and hooks. Users get Larry (AI teaching personality) plus a structured Data Room that passively captures insights and proactively surfaces gaps, contradictions, and convergence signals.

## UI Enforcement (MANDATORY)
All /mos: command output MUST follow the 4-zone anatomy from skills/ui-system/SKILL.md:
1. Header Panel (room name, command, venture stage)
2. Content Body (use the body_shape declared in the command's frontmatter)
3. Intelligence Strip (conditional -- show if proactive findings exist)
4. Action Footer (NEVER omit -- always suggest 2-3 next commands)

Symbol vocabulary: use ONLY these glyphs: ■ ▼ ▶ ▷ ├─ └─ ✓ • ⚠ ⚡ ⬜ →
Colors: green=success, cyan=info, yellow=warning, red=critical, gray=muted
NO EMOJI anywhere in output. NO exceptions.

## Dashboard Export Integrity (MANDATORY)
When generating a dashboard, room export, or standalone HTML visualization:
- ALWAYS use scripts/generate-standalone or scripts/serve-dashboard
- NEVER generate HTML by hand -- the template at dashboard/index.html has full Cytoscape.js graph, De Stijl styling, intelligence panel, layer toggles, and chat UI
- Improvised HTML will always be inferior to the real template

## JTBD Greeting Rules (MANDATORY)
1. Greet with awareness of where they left off -- reference specific room state (venture stage, entry counts, section names)
2. Present the JTBD nudges below as your suggestions. Use your own voice (signature openers like \"Here's the thing...\" or \"Very simply...\") but keep the nudge CONTENT exactly as written -- they are calibrated.
3. NEVER describe features or slash commands abstractly. Every suggestion must reference what the USER HAS and what they will GET.
4. Max 2-3 suggestions per greeting. Quality over quantity.
5. After your greeting and nudges, show the command menu exactly as formatted below."

# =============================================================================
# DYNAMIC SUFFIX (changes per session -- room state, proactive signals, nudges)
# =============================================================================

context=""

if [ -d "$ROOM_DIR" ]; then
  # Room exists -- compute state and build context
  state_output=$("${SCRIPT_DIR}/compute-state" "$ROOM_DIR" 2>/dev/null || echo "Error computing state")

  # Read USER.md if exists
  user_context=""
  if [ -f "${ROOM_DIR}/USER.md" ]; then
    user_context=$(cat "${ROOM_DIR}/USER.md" 2>/dev/null || true)
  fi

  # Read existing STATE.md if exists (last persisted state)
  state_md=""
  if [ -f "${ROOM_DIR}/STATE.md" ]; then
    state_md=$(cat "${ROOM_DIR}/STATE.md" 2>/dev/null || true)
  fi

  # Run proactive Room analysis
  proactive_output=$("${SCRIPT_DIR}/analyze-room" "$ROOM_DIR" 2>/dev/null || echo "")

  # Build dynamic context with room overview
  context="\n\n--- DYNAMIC SESSION CONTEXT ---\n\n[Room State]\n${state_output}"

  if [ -n "$user_context" ]; then
    context="${context}\n\nUser context:\n${user_context}"
  fi

  # Append proactive Room intelligence if available
  if [ -n "$proactive_output" ] && [ "$proactive_output" != "NO_ROOM" ]; then
    context="${context}\n\n## Proactive Room Intelligence\n${proactive_output}"
  fi

  # Read context bridge file if available
  CTX_BUDGET=""
  BRIDGE_FILE="/tmp/mindrian-context-state"
  if [ -f "$BRIDGE_FILE" ]; then
    # Check staleness (> 5 min = stale)
    BRIDGE_AGE=$(( $(date +%s) - $(stat -c %Y "$BRIDGE_FILE" 2>/dev/null || echo 0) ))
    if [ "$BRIDGE_AGE" -lt 300 ]; then
      CTX_MODEL=$(grep "^MODEL_NAME=" "$BRIDGE_FILE" | cut -d= -f2-)
      CTX_PCT=$(grep "^CTX_PCT=" "$BRIDGE_FILE" | cut -d= -f2-)
      CTX_SIZE=$(grep "^CTX_SIZE=" "$BRIDGE_FILE" | cut -d= -f2-)
      if [ -n "$CTX_PCT" ]; then
        CTX_BUDGET="[Context Budget] Model: ${CTX_MODEL:-unknown}, Usage: ${CTX_PCT}%, Window: ${CTX_SIZE:-200000} tokens"
        # Add warning if above threshold
        CTX_INT="${CTX_PCT%.*}"
        if [ "${CTX_INT:-0}" -ge 85 ]; then
          CTX_BUDGET="${CTX_BUDGET} -- CRITICAL: Consider suggesting /clear"
        elif [ "${CTX_INT:-0}" -ge 70 ]; then
          CTX_BUDGET="${CTX_BUDGET} -- WARNING: Context getting tight"
        fi
      fi
    fi
  fi

  if [ -n "$CTX_BUDGET" ]; then
    context="${context}\n\n${CTX_BUDGET}"
  fi

  # Detect integrations
  INTEG_OUTPUT=$(node "${PLUGIN_ROOT}/bin/mindrian-tools.cjs" detect-integrations 2>/dev/null || echo "{}")
  INTEG_COUNT=$(echo "$INTEG_OUTPUT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(sum(1 for v in d.values() if v.get('status')=='connected'))" 2>/dev/null || echo "0")

  if [ "$INTEG_COUNT" -gt 0 ]; then
    context="${context}\n\nIntegrations: ${INTEG_COUNT} connected"
  fi

  # Track session analytics
  bash "${SCRIPT_DIR}/track-analytics" session-start 2>/dev/null &

  # Generate learnings from usage patterns
  bash "${SCRIPT_DIR}/learn-from-usage" 2>/dev/null

  # Load learnings if available
  if [ -f "${ROOM_DIR}/.learnings.md" ]; then
    learnings=$(cat "${ROOM_DIR}/.learnings.md" 2>/dev/null || true)
    if [ -n "$learnings" ]; then
      context="${context}\n\n## Usage Learnings (adapt your behavior accordingly)\n${learnings}"
    fi
  fi

  # Multi-room context (ROOM-05)
  REGISTRY="${WORK_DIR}/.rooms/registry.json"
  if [ -f "$REGISTRY" ]; then
    room_count=$(python3 -c "
import json
r = json.load(open('$REGISTRY'))
print(len(r.get('rooms', {})))
" 2>/dev/null || echo "0")

    if [ "$room_count" -gt 1 ]; then
      other_rooms=$(python3 -c "
import json, datetime
r = json.load(open('$REGISTRY'))
active = r.get('active', '')
lines = []
for name, room in r.get('rooms', {}).items():
    if name == active:
        continue
    status = room.get('status', 'parked')
    sym = chr(9654) if status == 'parked' else chr(9655)
    display_name = room.get('venture_name', name)
    line = f'  {sym} {display_name:<25s} {status}'
    lines.append(line)
if lines:
    print('\n'.join(lines[:5]))
if len(lines) > 5:
    print(f'  ...and {len(lines)-5} more (/mos:rooms list)')
" 2>/dev/null || echo "")

      if [ -n "$other_rooms" ]; then
        context="${context}\n\n  Other rooms:\n${other_rooms}\n\n  ▷ /mos:rooms                      Manage your rooms"
      fi
    fi
  fi

  # Generate JTBD nudges + dynamic command menu
  jtbd_output=$("${SCRIPT_DIR}/build-jtbd-nudges" "$ROOM_DIR" "$PLUGIN_ROOT" 2>/dev/null || echo "")

  # Add nudges to dynamic context
  context="${context}\n\n## Your Nudges for This Session\n${jtbd_output}"

  # Combine: stable prefix + dynamic suffix
  context="${stable_prefix}${context}\n\nThe user has an active Data Room."
else
  # Cold start: show De Stijl Mondrian banner on EVERY cold start (no room detected)
  if [ -n "$LAST_VERSION" ] && [ "$LAST_VERSION" != "$PLUGIN_VERSION" ]; then
    # Plugin was updated -- show version transition banner
    bash "${SCRIPT_DIR}/banner" "$PLUGIN_VERSION" "$LAST_VERSION" >&2 2>/dev/null || true
  else
    # Standard cold start or first install -- show current version banner
    bash "${SCRIPT_DIR}/banner" "$PLUGIN_VERSION" >&2 2>/dev/null || true
  fi

  # Determine onboarding type from LAST_VERSION markers (kept separate from banner)
  if [ -z "$LAST_VERSION" ]; then
    # First-ever cold start -- no marker file exists
    :
  elif [ "$LAST_VERSION" != "$PLUGIN_VERSION" ]; then
    # Plugin was updated
    :
  fi
  # Update marker (D-02) -- write current version after banner fires
  echo "$PLUGIN_VERSION" > "$LAST_VERSION_FILE" 2>/dev/null || true

  # Check onboarding status (per ONBOARD-01)
  ONBOARD_STATUS=$("${SCRIPT_DIR}/check-onboard" 2>/dev/null || echo "CURRENT")
  ONBOARD_TYPE=$(echo "$ONBOARD_STATUS" | head -1)

  COLD_START_MENU="---\nGet started:\n  /mos:new-project .... Start a new venture project\n  /mos:help ........... See what Larry can help with\n  /mos:diagnose ....... Classify your problem type\n\nOr just talk -- Larry is a thinking partner first.\nType /mos: to see all 45 commands.\n  /mos:update ......... Check for latest features\n---"

  if [ "$ONBOARD_TYPE" = "FIRST_INSTALL" ]; then
    context="${stable_prefix}\n\n--- DYNAMIC SESSION CONTEXT ---\n\n[MindrianOS Onboarding] First install detected.\n\nThis is the user's very first session with MindrianOS. Welcome them warmly using one of your signature openers (\"Very simply...\", \"Here's the thing...\", \"One thing I've learned...\"). Be conversational and direct. No emoji. No filler phrases like \"I'd be happy to help\" or \"Great question!\".\n\nYour goal: build deep context about this user so every future interaction is smarter.\n\nStart by asking who they are and what they do. Frame it as valuable, not bureaucratic: \"Five minutes here saves hours later -- I'll know your domain, your goals, and how to actually help.\"\n\nOffer three approaches:\n1. Conversational Q&A -- you ask 3-5 questions about their role, domain, current focus, and goals\n2. Document paste -- \"Paste your LinkedIn bio or a short blurb about yourself and I'll build your profile from that\"\n3. Skip -- \"You can skip this entirely and jump straight to working. I'll learn about you as we go.\"\n\nIf the user engages with approach 1 or 2, build a USER.md file in their home directory (~/.mindrian-user.md) capturing: name, role, domain, subdomain, technical level, current focus, goal, expertise areas.\n\nIf they provide context, follow up with domain intelligence: \"Based on your work in [domain], here is what I already know about your space\" -- then suggest relevant frameworks and room sections.\n\nAfter building context OR if the user skips, present capabilities as natural actions (not slash commands):\n- You can tell Larry about a meeting you had and he will file and analyze it\n- You can ask Larry to diagnose what type of problem you are working on\n- You can ask Larry to grade your venture honestly\n- You can ask Larry to find relevant grants and opportunities\n- You can ask Larry to get 6 different perspectives on your work\n- You can ask Larry to query your knowledge graph\n- You can start a new project and Larry will set up your Data Room\n\nAfter the onboarding conversation completes or the user skips, run: bash \"${PLUGIN_ROOT}/scripts/check-onboard\" --write\n\nThen show the command menu below.\n\n${COLD_START_MENU}"

  elif [ "$ONBOARD_TYPE" = "UPDATE" ]; then
    PREV_VER=$(echo "$ONBOARD_STATUS" | grep "^PREVIOUS=" | cut -d= -f2)
    CHANGELOG_DIFF=$(sed -n "/^## \[${PLUGIN_VERSION}\]/,/^## \[${PREV_VER}\]/p" "$PLUGIN_ROOT/CHANGELOG.md" 2>/dev/null | head -n -1 | grep "^- " || echo "")
    ONBOARD_STEPS=$(sed -n "/^## \[${PLUGIN_VERSION}\]/,/^## \[/{ /^  - \"/p; }" "$PLUGIN_ROOT/CHANGELOG.md" 2>/dev/null | sed 's/^  - "//;s/"$//' || echo "")

    WHATS_NEW=""
    if [ -n "$ONBOARD_STEPS" ]; then
      WHATS_NEW="$ONBOARD_STEPS"
    elif [ -n "$CHANGELOG_DIFF" ]; then
      WHATS_NEW="$CHANGELOG_DIFF"
    fi

    context="${stable_prefix}\n\n--- DYNAMIC SESSION CONTEXT ---\n\n[Update] v${PREV_VER} -> v${PLUGIN_VERSION}.\n\nWelcome back. The user has updated from v${PREV_VER} to v${PLUGIN_VERSION}. Greet them warmly using a signature opener. No emoji. No filler.\n\nSince they last checked in, here is what you learned to do:\n${WHATS_NEW}\n\nCRITICAL: Frame EVERY new capability using the JTBD formula:\n\"When [situation the user faces], you want to [progress they are trying to make], so you can [outcome]. Now you can: /mos:command\"\n\nDo NOT list features technically. Instead, for each new capability:\n1. Name a REAL struggling moment the user has (based on what venture builders actually face)\n2. Show how this capability REMOVES that struggle\n3. End with the specific command and time estimate\n\nExample for model routing: \"When you are running deep methodology sessions and burning through tokens, you want to control cost without sacrificing teaching quality. Now you can: /mos:models set balanced -- Opus for teaching, Haiku for scanning, 66% less cost.\"\n\nExample for parallel agents: \"When you have 3 weak Sections and only 30 minutes before a meeting, you want to fill all the gaps at once. Now you can: /mos:act --swarm -- 3 frameworks in parallel, 5 minutes instead of 45.\"\n\nAfter showing what is new with JTBD framing, offer the full tour: \"Want to see everything? /mos:onboard -- 7 steps, 3 minutes.\"\n\nThen run: bash \"${PLUGIN_ROOT}/scripts/check-onboard\" --write\n\nThen show the command menu below.\n\n${COLD_START_MENU}"

  else
    # CURRENT -- existing cold-start behavior
    context="${stable_prefix}\n\n--- DYNAMIC SESSION CONTEXT ---\n\nNo room initialized yet. If the user wants to start a venture project, suggest /mos:new-project to get started. Otherwise, help them with whatever they need -- you're a thinking partner first.\n\nAFTER your greeting, ALWAYS show this command menu (copy exactly):\n\n${COLD_START_MENU}"
  fi
fi

# Auto-configure statusline — use MindrianOS status line when room/ exists
# Falls through to existing statusline (e.g. GSD) when no room present
CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
CLAUDE_SETTINGS="${CLAUDE_CONFIG_DIR}/settings.json"
if [ -f "$CLAUDE_SETTINGS" ] && [ -n "$ROOM_DIR" ] && [ -d "$ROOM_DIR" ]; then
  # Room exists — ensure MindrianOS statusline is active
  CURRENT_STATUSLINE=$(python3 -c "import json; d=json.load(open('$CLAUDE_SETTINGS')); sl=d.get('statusLine',{}); print(sl.get('command',''))" 2>/dev/null || echo "")
  if [[ "$CURRENT_STATUSLINE" != *"context-monitor"* ]]; then
    # Save the current statusline as fallback, set MindrianOS as active
    python3 -c "
import json
with open('$CLAUDE_SETTINGS', 'r') as f:
    d = json.load(f)
# Store original statusline for restoration when leaving MindrianOS project
if d.get('statusLine') and 'context-monitor' not in d['statusLine'].get('command',''):
    d['_savedStatusLine'] = d['statusLine']
d['statusLine'] = {'type': 'command', 'command': 'node \"$PLUGIN_ROOT/scripts/context-monitor\"'}
with open('$CLAUDE_SETTINGS', 'w') as f:
    json.dump(d, f, indent=2)
" 2>/dev/null || true
  fi
elif [ -f "$CLAUDE_SETTINGS" ] && { [ -z "$ROOM_DIR" ] || [ ! -d "$ROOM_DIR" ]; }; then
  # No room — restore saved statusline if we swapped it
  python3 -c "
import json
with open('$CLAUDE_SETTINGS', 'r') as f:
    d = json.load(f)
if '_savedStatusLine' in d:
    d['statusLine'] = d.pop('_savedStatusLine')
    with open('$CLAUDE_SETTINGS', 'w') as f:
        json.dump(d, f, indent=2)
" 2>/dev/null || true
fi

# Check for updates (async, non-blocking, max 3 second timeout)
# Only check once per day — cache result
UPDATE_CACHE="/tmp/mindrian-update-check"
TODAY=$(date -u +"%Y-%m-%d")
SHOULD_CHECK=true

if [ -f "$UPDATE_CACHE" ]; then
  CACHE_DATE=$(head -1 "$UPDATE_CACHE" 2>/dev/null || echo "")
  if [ "$CACHE_DATE" = "$TODAY" ]; then
    SHOULD_CHECK=false
    # Read cached result
    CACHED_STATUS=$(sed -n '2p' "$UPDATE_CACHE" 2>/dev/null || echo "")
    if [ "$CACHED_STATUS" = "UPDATE_AVAILABLE" ]; then
      CACHED_LATEST=$(sed -n '3p' "$UPDATE_CACHE" 2>/dev/null || echo "")
      context="${context}\n\n[Update Available] MindrianOS ${CACHED_LATEST} is available. Run /mos:update to see what's new."
    fi
  fi
fi

if $SHOULD_CHECK; then
  # Run check in background, cache result
  (
    UPDATE_RESULT=$("${SCRIPT_DIR}/check-update" 2>/dev/null || echo "CHECK_FAILED")
    STATUS=$(echo "$UPDATE_RESULT" | head -1)
    echo "$TODAY" > "$UPDATE_CACHE"
    echo "$STATUS" >> "$UPDATE_CACHE"
    if [ "$STATUS" = "UPDATE_AVAILABLE" ]; then
      LATEST=$(echo "$UPDATE_RESULT" | grep "^LATEST=" | cut -d= -f2)
      echo "$LATEST" >> "$UPDATE_CACHE"
    fi
  ) &
fi

# Escape string for JSON embedding
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

escaped_context=$(escape_for_json "$context")

# Output context injection as JSON
# Cursor hooks expect additional_context
# Claude Code hooks expect hookSpecificOutput.additionalContext
# Only emit the field consumed by the current platform to avoid double injection
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
fi

exit 0
