#!/usr/bin/env bash
# session-start: SessionStart hook handler for MindrianOS
# Loads room context into Claude's additionalContext for session continuity
# Must complete in under 2 seconds

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Determine working directory (where user's project is)
WORK_DIR="${PWD}"
ROOM_DIR="${WORK_DIR}/room"

# Read current version from plugin.json
PLUGIN_VERSION=$(python3 -c "import json; print(json.load(open('$PLUGIN_ROOT/.claude-plugin/plugin.json'))['version'])" 2>/dev/null || echo "unknown")

# Build context string
context=""

if [ -d "$ROOM_DIR" ]; then
  # Room exists -- compute state and build context
  state_output=$("${SCRIPT_DIR}/compute-state" "$ROOM_DIR" 2>/dev/null || echo "Error computing state")

  # Read USER.md if exists
  user_context=""
  if [ -f "${ROOM_DIR}/USER.md" ]; then
    user_context=$(cat "${ROOM_DIR}/USER.md" 2>/dev/null || true)
  fi

  # Read existing STATE.md if exists (last persisted state)
  state_md=""
  if [ -f "${ROOM_DIR}/STATE.md" ]; then
    state_md=$(cat "${ROOM_DIR}/STATE.md" 2>/dev/null || true)
  fi

  # Run proactive Room analysis
  proactive_output=$("${SCRIPT_DIR}/analyze-room" "$ROOM_DIR" 2>/dev/null || echo "")

  # Build context with room overview
  context="[MindrianOS Room Context]\n\nCurrent room state:\n${state_output}"

  if [ -n "$user_context" ]; then
    context="${context}\n\nUser context:\n${user_context}"
  fi

  # Append proactive Room intelligence if available
  if [ -n "$proactive_output" ] && [ "$proactive_output" != "NO_ROOM" ]; then
    context="${context}\n\n## Proactive Room Intelligence\n${proactive_output}"
  fi

  # Read context bridge file if available
  CTX_BUDGET=""
  BRIDGE_FILE="/tmp/mindrian-context-state"
  if [ -f "$BRIDGE_FILE" ]; then
    # Check staleness (> 5 min = stale)
    BRIDGE_AGE=$(( $(date +%s) - $(stat -c %Y "$BRIDGE_FILE" 2>/dev/null || echo 0) ))
    if [ "$BRIDGE_AGE" -lt 300 ]; then
      CTX_MODEL=$(grep "^MODEL_NAME=" "$BRIDGE_FILE" | cut -d= -f2-)
      CTX_PCT=$(grep "^CTX_PCT=" "$BRIDGE_FILE" | cut -d= -f2-)
      CTX_SIZE=$(grep "^CTX_SIZE=" "$BRIDGE_FILE" | cut -d= -f2-)
      if [ -n "$CTX_PCT" ]; then
        CTX_BUDGET="[Context Budget] Model: ${CTX_MODEL:-unknown}, Usage: ${CTX_PCT}%, Window: ${CTX_SIZE:-200000} tokens"
        # Add warning if above threshold
        CTX_INT="${CTX_PCT%.*}"
        if [ "${CTX_INT:-0}" -ge 85 ]; then
          CTX_BUDGET="${CTX_BUDGET} -- CRITICAL: Consider suggesting /clear"
        elif [ "${CTX_INT:-0}" -ge 70 ]; then
          CTX_BUDGET="${CTX_BUDGET} -- WARNING: Context getting tight"
        fi
      fi
    fi
  fi

  if [ -n "$CTX_BUDGET" ]; then
    context="${context}\n\n${CTX_BUDGET}"
  fi

  # Detect integrations
  INTEG_OUTPUT=$(node "${PLUGIN_ROOT}/bin/mindrian-tools.cjs" detect-integrations 2>/dev/null || echo "{}")
  INTEG_COUNT=$(echo "$INTEG_OUTPUT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(sum(1 for v in d.values() if v.get('status')=='connected'))" 2>/dev/null || echo "0")

  if [ "$INTEG_COUNT" -gt 0 ]; then
    context="${context}\n\nIntegrations: ${INTEG_COUNT} connected"
  fi

  # Track session analytics
  bash "${SCRIPT_DIR}/track-analytics" session-start 2>/dev/null &

  # Generate learnings from usage patterns
  bash "${SCRIPT_DIR}/learn-from-usage" 2>/dev/null

  # Load learnings if available
  if [ -f "${ROOM_DIR}/.learnings.md" ]; then
    learnings=$(cat "${ROOM_DIR}/.learnings.md" 2>/dev/null || true)
    if [ -n "$learnings" ]; then
      context="${context}\n\n## Usage Learnings (adapt your behavior accordingly)\n${learnings}"
    fi
  fi

  # Add venture stage and suggested action from state
  context="${context}\n\nYou are Larry. MindrianOS v${PLUGIN_VERSION}. The user has an active Data Room. Greet them with awareness of where they left off and suggest what to work on next based on the gaps above.\n\nAFTER your greeting, ALWAYS show this command menu (copy exactly):\n\n---\nQuick commands (type /mos: to see all):\n  /mos:help ........... Larry recommends what to do next\n  /mos:status ......... See your Data Room state\n  /mos:diagnose ....... Classify your problem type\n  /mos:file-meeting ... File a meeting transcript\n  /mos:opportunities .. Discover relevant grants\n  /mos:persona ........ Get 6 perspectives on your work\n  /mos:query .......... Ask your knowledge graph anything\n  /mos:grade .......... Honest assessment of your venture\n  /mos:update ......... Check for latest features\n---"
else
  context="[MindrianOS] No room initialized yet. MindrianOS v${PLUGIN_VERSION}. You are Larry. If the user wants to start a venture project, suggest /mos:new-project to get started. Otherwise, help them with whatever they need -- you're a thinking partner first.\n\nAFTER your greeting, ALWAYS show this command menu (copy exactly):\n\n---\nGet started:\n  /mos:new-project .... Start a new venture project\n  /mos:help ........... See what Larry can help with\n  /mos:diagnose ....... Classify your problem type\n\nOr just talk — Larry is a thinking partner first.\nType /mos: to see all 45 commands.\n  /mos:update ......... Check for latest features\n---"
fi

# Auto-configure statusline — use MindrianOS status line when room/ exists
# Falls through to existing statusline (e.g. GSD) when no room present
CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
CLAUDE_SETTINGS="${CLAUDE_CONFIG_DIR}/settings.json"
if [ -f "$CLAUDE_SETTINGS" ] && [ -d "$ROOM_DIR" ]; then
  # Room exists — ensure MindrianOS statusline is active
  CURRENT_STATUSLINE=$(python3 -c "import json; d=json.load(open('$CLAUDE_SETTINGS')); sl=d.get('statusLine',{}); print(sl.get('command',''))" 2>/dev/null || echo "")
  if [[ "$CURRENT_STATUSLINE" != *"context-monitor"* ]]; then
    # Save the current statusline as fallback, set MindrianOS as active
    python3 -c "
import json
with open('$CLAUDE_SETTINGS', 'r') as f:
    d = json.load(f)
# Store original statusline for restoration when leaving MindrianOS project
if d.get('statusLine') and 'context-monitor' not in d['statusLine'].get('command',''):
    d['_savedStatusLine'] = d['statusLine']
d['statusLine'] = {'type': 'command', 'command': 'node \"$PLUGIN_ROOT/scripts/context-monitor\"'}
with open('$CLAUDE_SETTINGS', 'w') as f:
    json.dump(d, f, indent=2)
" 2>/dev/null || true
  fi
elif [ -f "$CLAUDE_SETTINGS" ] && [ ! -d "$ROOM_DIR" ]; then
  # No room — restore saved statusline if we swapped it
  python3 -c "
import json
with open('$CLAUDE_SETTINGS', 'r') as f:
    d = json.load(f)
if '_savedStatusLine' in d:
    d['statusLine'] = d.pop('_savedStatusLine')
    with open('$CLAUDE_SETTINGS', 'w') as f:
        json.dump(d, f, indent=2)
" 2>/dev/null || true
fi

# Check for updates (async, non-blocking, max 3 second timeout)
# Only check once per day — cache result
UPDATE_CACHE="/tmp/mindrian-update-check"
TODAY=$(date -u +"%Y-%m-%d")
SHOULD_CHECK=true

if [ -f "$UPDATE_CACHE" ]; then
  CACHE_DATE=$(head -1 "$UPDATE_CACHE" 2>/dev/null || echo "")
  if [ "$CACHE_DATE" = "$TODAY" ]; then
    SHOULD_CHECK=false
    # Read cached result
    CACHED_STATUS=$(sed -n '2p' "$UPDATE_CACHE" 2>/dev/null || echo "")
    if [ "$CACHED_STATUS" = "UPDATE_AVAILABLE" ]; then
      CACHED_LATEST=$(sed -n '3p' "$UPDATE_CACHE" 2>/dev/null || echo "")
      context="${context}\n\n[Update Available] MindrianOS ${CACHED_LATEST} is available. Run /mos:update to see what's new."
    fi
  fi
fi

if $SHOULD_CHECK; then
  # Run check in background, cache result
  (
    UPDATE_RESULT=$("${SCRIPT_DIR}/check-update" 2>/dev/null || echo "CHECK_FAILED")
    STATUS=$(echo "$UPDATE_RESULT" | head -1)
    echo "$TODAY" > "$UPDATE_CACHE"
    echo "$STATUS" >> "$UPDATE_CACHE"
    if [ "$STATUS" = "UPDATE_AVAILABLE" ]; then
      LATEST=$(echo "$UPDATE_RESULT" | grep "^LATEST=" | cut -d= -f2)
      echo "$LATEST" >> "$UPDATE_CACHE"
    fi
  ) &
fi

# Escape string for JSON embedding
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

escaped_context=$(escape_for_json "$context")

# Output context injection as JSON
# Cursor hooks expect additional_context
# Claude Code hooks expect hookSpecificOutput.additionalContext
# Only emit the field consumed by the current platform to avoid double injection
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
fi

exit 0
